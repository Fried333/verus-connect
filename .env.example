# Required — your app's VerusID credentials
SIGNING_IADDRESS=iYourVerusID...
PRIVATE_KEY=UxYourWIFKey...

# Required — public URL where Verus Mobile will POST the login response
# This must be reachable from the internet (not localhost)
CALLBACK_URL=https://yoursite.com/verus/verusidlogin

# Optional — server config
PORT=8100
HOST=127.0.0.1

# Optional — chain config (defaults to VRSC mainnet)
CHAIN=VRSC
API_URL=https://api.verus.services
CHAIN_IADDRESS=i5w5MuNik5NtLcYmNzcvaoixooEebB6MGV

# Optional — CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
