{
  "name": "verus-connect",
  "version": "3.0.0",
  "description": "Drop-in VerusID login for any website — standalone server + Express middleware + frontend SDK",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "verus-connect": "dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.cjs start"
  },
  "keywords": [
    "verus",
    "verusid",
    "crypto",
    "wallet",
    "login",
    "blockchain",
    "authentication",
    "sidecar"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/connect": "^3.4.38",
    "@types/express": "^4.17.25",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.15.0",
    "@types/range-parser": "^1.2.7",
    "@types/send": "^1.2.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "qrcode-generator": "1.4.4"
  },
  "peerDependencies": {
    "verusid-ts-client": "*"
  },
  "peerDependenciesMeta": {
    "verusid-ts-client": {
      "optional": true
    }
  }
}
