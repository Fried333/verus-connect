{
  "name": "verus-connect",
  "version": "4.0.0",
  "description": "VerusID authentication middleware — daemon mode or lite mode",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "verus-connect": "dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.cjs start",
    "install:lite": "npm install verusid-ts-client@github:VerusCoin/verusid-ts-client"
  },
  "license": "MIT",
  "dependencies": {
    "express": "4.22.1",
    "verus-typescript-primitives": "github:VerusCoin/verus-typescript-primitives#27e6c076def4416c20a568e31e4c406b10612807"
  },
  "devDependencies": {
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "@types/express": "4.17.25",
    "@types/node": "22.15.0"
  }
}
